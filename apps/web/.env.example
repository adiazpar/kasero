# Vite proxy target for /api/* requests in dev.
# Must match the apps/api dev server port.
VITE_API_PROXY_TARGET=https://localhost:8000

# Vite dev server port. Defaults to 3000.
VITE_WEB_PORT=3000

# Origin of the API used by the better-auth React client.
# Leave empty in production (same-origin SPA shell served by the API).
# For dev, the Vite proxy forwards /api/* to the API so this can stay empty too.
VITE_AUTH_BASE_URL=

# ---- Capacitor-native builds only (see .claude/docs/capacitor-native.md) ----
# Absolute origin of the deployed API, e.g. https://kasero.app. MUST stay
# empty for every web build — when unset, all fetches remain relative and
# web behavior is byte-identical. Set only when building the SPA bundle
# that ships inside the iOS/Android app (npm run cap:sync).
VITE_API_ORIGIN=

# Canonical public web origin embedded in shareable URLs (invite QR codes)
# when running inside the native WebView, e.g. https://kasero.app.
# Ignored on web (window.location.origin is used there).
VITE_PUBLIC_WEB_ORIGIN=
