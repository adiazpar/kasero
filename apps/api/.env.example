# ===========================================
# AUTH - better-auth (required)
# ===========================================
# Generate with: openssl rand -base64 32
# IMPORTANT: Use different secrets for dev and prod.
AUTH_SECRET=your-secret-key-min-32-chars-here

# Public origin of the API. In dev that's the API dev port; in prod the
# same origin that serves both /api/* and the SPA shell.
BETTER_AUTH_URL=http://localhost:8000

# Extra origins better-auth's CSRF check should accept beyond BETTER_AUTH_URL.
# Comma-separated. http://localhost:3000 and http://localhost:8000 are
# always trusted in code, so this is for non-localhost hosts you reach
# the dev server from — typically Tailscale MagicDNS/Funnel hostnames
# when testing on a phone or another device.
# Example: BETTER_AUTH_TRUSTED_ORIGINS=https://your-laptop.tail-xxxx.ts.net:3000
BETTER_AUTH_TRUSTED_ORIGINS=

# ===========================================
# OAuth providers
# ===========================================
# Google: console.cloud.google.com -> APIs & Services -> Credentials
#   -> Create Credentials -> OAuth Client ID -> Web Application
# Authorized redirect URIs:
#   http://localhost:8000/api/auth/callback/google  (dev)
#   https://kasero.app/api/auth/callback/google     (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple: developer.apple.com -> Certificates, Identifiers & Profiles
# One-time setup steps documented in tech-stack.md (Auth section).
# Authorized return URL (production only — Apple's Services ID has a 10-URL
# cap and we don't register preview/local URLs):
#   https://kasero.app/api/auth/callback/apple
#
# All four below are required to activate the Apple provider. The
# private key is the verbatim contents of the .p8 file Apple lets you
# download once when you create the Sign In with Apple key.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Uncomment and set to the iOS app's Bundle ID when the native app ships;
# enables verification of identity-tokens sent from the native flow.
# APPLE_APP_BUNDLE_IDENTIFIER=

# ===========================================
# Apple App Review demo account (optional)
# ===========================================
# App Store guideline 2.1: Apple's reviewers sign in with a designated
# demo account but cannot receive OTP emails, so sign-in for exactly
# APP_REVIEW_EMAIL accepts the static APP_REVIEW_OTP code and no OTP
# email is sent for that address. The feature is entirely inert unless
# BOTH vars are set; APP_REVIEW_OTP must be 6+ digits or it stays inert.
# The static code is never valid for any other account.
# Leave both empty everywhere except the production env during review.
# Values live in Bitwarden ("Kasero — Vercel project envs"), per the
# project convention — this file documents the shape only.
APP_REVIEW_EMAIL=
APP_REVIEW_OTP=

# ===========================================
# Email (Resend)
# ===========================================
# 1. Create an account at resend.com
# 2. Add and verify the sending domain (SPF + DKIM + DMARC DNS records)
# 3. API Keys -> Create API Key (full access)
# 4. EMAIL_FROM must use a verified domain
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="Kasero <noreply@kasero.app>"

# ===========================================
# Cron - shared secret for /api/cron/* endpoints
# ===========================================
# Generate with: openssl rand -base64 32
# Set in Vercel: Project -> Settings -> Cron Jobs -> Authorization header.
CRON_SECRET=your-cron-secret

# ===========================================
# DATABASE - Turso (production only)
# ===========================================
# Used by the app in production and by `npm run db:push:prod`.
# In development, the API uses a local SQLite file (data/local.db) automatically.
# 1. Install CLI: brew install tursodatabase/tap/turso
# 2. Login:       turso auth login
# 3. Create DB:   turso db create pos
# 4. Get URL:     turso db show pos --url
# 5. Get token:   turso db tokens create pos
TURSO_DATABASE_URL=libsql://pos-yourname.turso.io
TURSO_AUTH_TOKEN=eyJ...your-prod-token

# ===========================================
# AI Features (optional)
# ===========================================
# OpenAI - product identification (GPT-4o Mini Vision)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# fal.ai - emoji icon generation, background removal
# https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key

# IMPORTANT: configure spending alerts on BOTH provider dashboards. The
# app enforces three layers of rate limiting (per-minute per-user, per-day
# per-user, global per-day) but those are insurance, not guarantees against
# misconfiguration. Recommended:
#   - OpenAI: Settings -> Billing -> Usage limits (soft + hard caps)
#   - fal.ai: Dashboard -> Billing -> Budget alerts (email at $X/day)

# ===========================================
# Kasero Pro — promo codes (optional)
# ===========================================
# Marketing/beta grants for the Pro tier, redeemed at
# POST /api/businesses/[businessId]/subscription/redeem. Comma-separated
# `CODE:months` entries; codes match case-insensitively. Unset/empty
# means every redeem attempt returns SUBSCRIPTION_INVALID_CODE.
# Example: PRO_PROMO_CODES=LAUNCHCREW:12,BETATHANKS:3
# Values live in Bitwarden ("Kasero — Vercel project envs").
PRO_PROMO_CODES=

# ===========================================
# Kasero Pro — store billing adapters (optional, unwired)
# ===========================================
# Server-side receipt verification for paid Pro subscriptions. Until ALL
# of a platform's vars are set, /subscription/verify-purchase returns
# 503 SUBSCRIPTION_NOT_CONFIGURED for that platform. Wiring steps are
# documented in apps/api/src/lib/billing/apple.ts and google.ts.
#
# Apple App Store Server API (App Store Connect -> Integrations ->
# In-App Purchase key):
APPLE_IAP_KEY_ID=
APPLE_IAP_ISSUER_ID=
# Verbatim contents of the .p8 private key file.
APPLE_IAP_PRIVATE_KEY=
APPLE_IAP_BUNDLE_ID=
#
# Google Play Developer API (Play Console -> Setup -> API access
# service account):
# Full service-account JSON key, verbatim.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=

# ===========================================
# Distributed rate limiting (optional, production)
# ===========================================
# When both vars are set, checkRateLimit() delegates to Upstash Redis so
# counters are shared across Lambda instances. Without them, the in-memory
# fallback runs (fine for local dev, NOT appropriate for multi-instance prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Standard Redis TCP/TLS endpoint on the same Upstash database. Used by
# the realtime subsystem (apps/api/src/lib/realtime/*) for pub/sub +
# Streams. Get this from the Upstash dashboard's TCP tab — the URL scheme
# must be rediss:// (TLS).
#
# IMPORTANT: This key is intentionally Vercel-only (Production + Preview).
# Do NOT set it in your local apps/api/.env.local — local dev uses an
# in-memory realtime backend so dev publishes never reach prod clients.
# Setting it locally will route your local pub/sub through prod Upstash
# and accidentally broadcast to real connected users.
UPSTASH_REDIS_URL=

# ===========================================
# i18n translate script (dev-only)
# ===========================================
# Used only by `npm run i18n:translate` to generate non-English message
# bundles via the Claude API. Local-only; never read at runtime and never
# needed in Vercel env vars.
# https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===========================================
# Local dev port
# ===========================================
# The dev script reads API_PORT (defaults to 8000) for the --port flag.
# A custom name is used because some shells export PORT=<other> for unrelated
# projects, and Next.js's PORT env would override .env.local silently.
# Must match the host in apps/web/.env.local's VITE_API_PROXY_TARGET.
#
# Also set PORT to the same value so server-side code that reads
# process.env.PORT (e.g. start:local) stays in sync with the dev bind.
API_PORT=8000
PORT=8000

# ===========================================
# STORAGE - no extra config needed
# ===========================================
# Development: files saved to public/media/ (gitignored)
# Production:  icons stored as base64 in Turso database
